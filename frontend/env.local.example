# Local Development Environment Variables
# This file is for local testing only

# API Configuration - Points to local backend
VITE_API_URL=http://localhost:3001/api

# Platform logout (Course Builder-compatible nAuth flow)
# VITE_NAUTH_BASE_URL is required for central nAuth logout (POST /auth/logout with credentials).
# VITE_NAUTH_FRONTEND_URL is required for redirect to the login page after logout.
# No DevLab backend env is required for logout. Logout does not use COORDINATOR_URL.
VITE_NAUTH_BASE_URL=https://your-nauth-backend.example.com
VITE_NAUTH_FRONTEND_URL=https://your-nauth-frontend.example.com

# Environment
NODE_ENV=development

# Competition Feature
VITE_COMPETITION_ENABLED=true
VITE_COMPETITION_TIMER_DURATION=600
VITE_COMPETITION_QUESTION_COUNT=3

# Sound Effects (for local testing)
VITE_SOUND_ENABLED=true
